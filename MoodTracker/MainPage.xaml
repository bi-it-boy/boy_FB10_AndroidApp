<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MoodTracker.MainPage" >


    <Grid
        Padding="16"
        RowDefinitions="Auto,Auto,*"
        RowSpacing="16">

        <Label
            Grid.Row="0"
            Text="Kurse"
            FontSize="28"
            FontAttributes="Bold" />

        <CollectionView
            x:Name="CourseCollectionView"
            Grid.Row="2"
            SelectionMode="None">   

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border
                        Margin="0,0,0,12"
                        Padding="16"
                        BackgroundColor="White"
                        Stroke="#DDDDDD"
                        StrokeThickness="1">    

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="8">

                            <Label
                                Text="{Binding Name}"
                                FontSize="18"
                                FontAttributes="Bold" />

                            <Label
                                Text="{Binding DateAndTime}"
                                FontSize="14"
                                TextColor="Gray" />

                            <Label
                                Text="{Binding Location, StringFormat='Ort: {0}'}"
                                FontSize="14"
                                TextColor="Gray" />

                            <Label
                                Text="{Binding Description}"
                                FontSize="14" />

                            <Label
                                Text="{Binding RatingText}"
                                FontSize="14"
                                TextColor="Gray" />

                            <Grid
                                ColumnDefinitions="*,*"
                                ColumnSpacing="8">

                                <Button
                                    Grid.Column="0"
                                    Text="Bewerten"
                                    Clicked="OnRateClicked" />

                            </Grid>

                        </VerticalStackLayout>

                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid> 

</ContentPage>
